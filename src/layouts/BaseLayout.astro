---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
}

const {
  title,
  description = "BoBlog — Blog modern yang dibangun dengan Astro.js",
  ogImage = "/og-default.png",
  canonicalUrl,
  noIndex = false,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || "http://localhost:4321";
const fullTitle = title ? `${title} | BoBlog` : "BoBlog";
const fullOgImage = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;
const canonical = canonicalUrl || Astro.url.href;
---

<!doctype html>
<html lang="id" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="BoBlog" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Generator -->
    <meta name="generator" content={Astro.generator} />

    <!-- Styles -->
    <link rel="stylesheet" href="/src/styles/global.css" />
  </head>
  <body class="min-h-screen bg-mesh text-base-content flex flex-col relative overflow-x-hidden">
    <!-- Background Animated Blobs -->
    <div class="fixed inset-0 pointer-events-none z-[-1] overflow-hidden">
      <div
        class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/20 rounded-full mix-blend-multiply filter blur-3xl animate-blob"
      >
      </div>
      <div
        class="absolute top-1/3 right-1/4 w-96 h-96 bg-secondary/20 rounded-full mix-blend-multiply filter blur-3xl animate-blob"
        style="animation-delay: 2s;"
      >
      </div>
      <div
        class="absolute bottom-1/4 left-1/2 w-96 h-96 bg-accent/20 rounded-full mix-blend-multiply filter blur-3xl animate-blob"
        style="animation-delay: 4s;"
      >
      </div>
    </div>

    <slot name="header">
      <header
        class="navbar glass-depth rounded-full w-11/12 max-w-6xl mx-auto my-4 sticky top-4 z-50 transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 preserve-3d"
      >
        <div class="navbar-start">
          <div class="dropdown">
            <div tabindex="0" role="button" class="btn btn-ghost lg:hidden">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h8m-8 6h16"></path>
              </svg>
            </div>
            <ul
              tabindex="0"
              class="menu menu-sm dropdown-content bg-base-200 rounded-box z-1 mt-3 w-52 p-2 shadow-xl"
            >
              <li><a href="/">Beranda</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/categories">Kategori</a></li>
              <li><a href="/about">Tentang</a></li>
            </ul>
          </div>
          <a href="/" class="btn btn-ghost text-xl font-bold">
            <span class="bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent">
              BoBlog
            </span>
          </a>
        </div>

        <div class="navbar-center hidden lg:flex">
          <ul class="menu menu-horizontal px-1 gap-1">
            <li><a href="/" class="rounded-lg">Beranda</a></li>
            <li><a href="/blog" class="rounded-lg">Blog</a></li>
            <li><a href="/categories" class="rounded-lg">Kategori</a></li>
            <li><a href="/about" class="rounded-lg">Tentang</a></li>
          </ul>
        </div>

        <div class="navbar-end gap-2">
          <!-- Search button -->
          <button class="btn btn-ghost btn-circle" aria-label="Cari">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>

          <!-- Theme toggle -->
          <label class="swap swap-rotate btn btn-ghost btn-circle">
            <input type="checkbox" id="theme-toggle" />
            <svg
              class="swap-off h-5 w-5 fill-current"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
            >
              <path
                d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"
              ></path>
            </svg>
            <svg
              class="swap-on h-5 w-5 fill-current"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
            >
              <path
                d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"
              ></path>
            </svg>
          </label>

          <!-- Auth buttons / User menu -->
          {
            Astro.locals.user ? (
              <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
                  <div class="w-8 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2">
                    <img
                      alt={Astro.locals.user.displayName}
                      src={
                        Astro.locals.user.avatar ||
                        `https://ui-avatars.com/api/?name=${encodeURIComponent(Astro.locals.user.displayName)}&background=random`
                      }
                    />
                  </div>
                </div>
                <ul
                  tabindex="0"
                  class="menu menu-sm dropdown-content bg-base-200 rounded-box z-1 mt-3 w-52 p-2 shadow-xl"
                >
                  <li class="menu-title px-4 py-2">
                    <span class="font-semibold">{Astro.locals.user.displayName}</span>
                    <span class="text-xs opacity-60">@{Astro.locals.user.username}</span>
                  </li>
                  <div class="divider my-0" />
                  <li>
                    <a href="/profile">Profil</a>
                  </li>
                  <li>
                    <a href="/bookmarks">Bookmark</a>
                  </li>
                  {["SUPER_ADMIN", "ADMIN", "EDITOR", "AUTHOR"].includes(
                    Astro.locals.user.role,
                  ) && (
                    <li>
                      <a href="/admin">Dashboard</a>
                    </li>
                  )}
                  <div class="divider my-0" />
                  <li>
                    <form method="POST" action="/api/auth/logout">
                      <button type="submit" class="w-full text-left text-error">
                        Keluar
                      </button>
                    </form>
                  </li>
                </ul>
              </div>
            ) : (
              <div class="flex gap-2">
                <a href="/auth/login" class="btn btn-ghost btn-sm">
                  Masuk
                </a>
                <a href="/auth/register" class="btn btn-primary btn-sm">
                  Daftar
                </a>
              </div>
            )
          }
        </div>
      </header>
    </slot>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="mt-20 relative preserve-3d">
      <div
        class="absolute inset-0 bg-linear-to-b from-transparent to-base-200/90 pointer-events-none -z-10"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-3/4 h-32 bg-primary/10 filter blur-[100px] pointer-events-none -z-10"
      >
      </div>

      <div
        class="footer footer-center p-10 bg-base-200/50 backdrop-blur-md border-t border-base-300 glass-depth rounded-t-[3rem] max-w-7xl mx-auto transform hover:translate-Z-[10px] transition-transform duration-500"
      >
        <aside class="flex flex-col items-center gap-4">
          <div
            class="w-16 h-16 rounded-full bg-linear-to-br from-primary to-secondary flex items-center justify-center shadow-lg shadow-primary/30 animate-float-slow"
          >
            <span class="text-3xl">☕</span>
          </div>
          <p class="font-black text-2xl tracking-tighter">
            <span
              class="bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent text-3d cursor-default"
              >BoBlog</span
            >
          </p>
          <p class="text-sm opacity-70 max-w-sm">
            Jelajahi ide terbaru dan kisah inspiratif melalui blog modern yang dirancang dengan
            performa mutakhir.
          </p>
          <p class="text-xs opacity-50 mt-4 font-mono">
            &copy; {new Date().getFullYear()} BoBlog. Crafted with 💻 in Astro.
          </p>
        </aside>

        <nav class="mt-6 w-full max-w-md mx-auto">
          <div class="flex justify-center flex-wrap gap-8">
            <a
              href="/rss.xml"
              class="link link-hover text-sm font-semibold hover:text-primary transition-colors"
              aria-label="RSS Feed">RSS</a
            >
            <a
              href="/sitemap-index.xml"
              class="link link-hover text-sm font-semibold hover:text-secondary transition-colors"
              aria-label="Sitemap">Sitemap</a
            >
            <a
              href="/about"
              class="link link-hover text-sm font-semibold hover:text-accent transition-colors"
              >Tentang</a
            >
          </div>
        </nav>
      </div>
    </footer>

    <!-- Back to top button -->
    <button
      id="back-to-top"
      class="btn btn-circle btn-primary fixed bottom-8 right-8 opacity-0 pointer-events-none transition-all duration-300 shadow-lg z-50"
      aria-label="Kembali ke atas"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M14.707 12.707a1 1 0 01-1.414 0L10 9.414l-3.293 3.293a1 1 0 01-1.414-1.414l4-4a1 1 0 011.414 0l4 4a1 1 0 010 1.414z"
          clip-rule="evenodd"></path>
      </svg>
    </button>

    <script>
      // Back to top button
      const backToTop = document.getElementById("back-to-top");
      if (backToTop) {
        window.addEventListener("scroll", () => {
          if (window.scrollY > 300) {
            backToTop.classList.remove("opacity-0", "pointer-events-none");
            backToTop.classList.add("opacity-100", "pointer-events-auto");
          } else {
            backToTop.classList.add("opacity-0", "pointer-events-none");
            backToTop.classList.remove("opacity-100", "pointer-events-auto");
          }
        });
        backToTop.addEventListener("click", () => {
          window.scrollTo({ top: 0, behavior: "smooth" });
        });
      }

      // Theme toggle functionality (Cinematic Radial Reveal)
      const themeToggle = document.getElementById("theme-toggle") as HTMLInputElement;

      if (themeToggle) {
        // Init visual sync
        const currentTheme = document.documentElement.getAttribute("data-theme");
        themeToggle.checked = currentTheme === "light";

        themeToggle.addEventListener("click", (e) => {
          e.preventDefault(); // Mencegah checkbox toggle native

          const isDark = document.documentElement.getAttribute("data-theme") === "dark";
          const newTheme = isDark ? "light" : "dark";

          const updateDOM = () => {
            document.documentElement.setAttribute("data-theme", newTheme);
            localStorage.setItem("theme", newTheme);
            themeToggle.checked = newTheme === "light";
          };

          if (
            !document.startViewTransition ||
            window.matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            updateDOM();
            return;
          }

          document.documentElement.setAttribute("data-theme-transition", "true");
          const transition = document.startViewTransition(updateDOM);

          transition.ready.then(() => {
            const x = e.clientX || window.innerWidth / 2;
            const y = e.clientY || window.innerHeight / 2;
            const endRadius = Math.hypot(
              Math.max(x, window.innerWidth - x),
              Math.max(y, window.innerHeight - y),
            );

            document.documentElement.animate(
              [
                { clipPath: `circle(0px at ${x}px ${y}px)` },
                { clipPath: `circle(${endRadius}px at ${x}px ${y}px)` },
              ],
              {
                duration: 800,
                easing: "cubic-bezier(0.25, 0.1, 0.25, 1)",
                pseudoElement: "::view-transition-new(root)",
              },
            );
          });

          transition.finished.finally(() => {
            document.documentElement.removeAttribute("data-theme-transition");
          });
        });
      }
    </script>
  </body>
</html>
