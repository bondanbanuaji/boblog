---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleCard from "@/components/blog/ArticleCard.astro";
import { db } from "@/lib/db";

const categorySlug = Astro.url.searchParams.get("category");
const tagSlug = Astro.url.searchParams.get("tag");
const query = Astro.url.searchParams.get("q") || "";

const whereClause: any = { status: "PUBLISHED" };

if (categorySlug) {
  whereClause.category = { slug: categorySlug };
}

if (tagSlug) {
  whereClause.tags = { some: { tag: { slug: tagSlug } } };
}

if (query) {
  whereClause.OR = [
    { title: { contains: query, mode: "insensitive" } },
    { content: { contains: query, mode: "insensitive" } },
  ];
}

const articles = await db.article.findMany({
  where: whereClause,
  include: {
    author: { select: { displayName: true, username: true, avatar: true } },
    category: { select: { name: true, slug: true, color: true } },
  },
  orderBy: { publishedAt: "desc" },
});

const categories = await db.category.findMany();

const activeFilter = categories.find((c) => c.slug === categorySlug);
---

<BaseLayout title="BoBlog - Semua Artikel" description="Jelajahi koleksi artikel lengkap di BoBlog">
  <main class="max-w-7xl mx-auto px-4 py-16 preserve-3d">
    <!-- Header Section -->
    <div class="text-center mb-16 animate-fade-in perspective-1000">
      <div
        class="inline-block px-6 py-2 glass-depth rounded-full text-sm font-bold text-primary mb-6 animate-float-slow"
        style="transform: translateZ(30px);"
      >
        📚 Koleksi Ilmu & Cerita
      </div>
      <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tighter text-3d">
        Eksplorasi <span
          class="bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent"
          >Artikel</span
        >
      </h1>
      <p class="text-lg opacity-70 max-w-2xl mx-auto leading-relaxed">
        {
          activeFilter
            ? `Menampilkan artikel dalam kategori "${activeFilter.name}"`
            : "Temukan wawasan terbaru dari berbagai topik menarik yang kami sajikan khusus untuk Anda."
        }
      </p>
    </div>

    <!-- 3D Search & Filter Box -->
    <div class="mb-20 perspective-1000">
      <form
        method="get"
        action="/blog"
        class="glass-depth p-4 md:p-6 rounded-[2.5rem] flex flex-col lg:flex-row gap-4 items-center transform hover:translate-z-4 transition-transform duration-500 border border-base-content/5 shadow-2xl"
      >
        <div class="relative w-full flex-1 group">
          <span
            class="absolute left-5 top-1/2 -translate-y-1/2 text-xl opacity-40 group-focus-within:opacity-100 transition-opacity"
            >🔍</span
          >
          <input
            type="text"
            name="q"
            placeholder="Cari judul atau isi artikel..."
            class="input input-lg w-full pl-14 rounded-3xl bg-base-100/50 border-none ring-1 ring-base-content/10 focus:ring-2 focus:ring-primary transition-all text-base"
            value={query}
          />
        </div>

        <div class="w-full lg:w-64">
          <select
            name="category"
            class="select select-lg w-full rounded-3xl bg-base-100/50 border-none ring-1 ring-base-content/10 focus:ring-2 focus:ring-primary transition-all text-base"
            onchange="this.form.submit()"
          >
            <option value="">Semua Kategori</option>
            {
              categories.map((c) => (
                <option value={c.slug} selected={c.slug === categorySlug}>
                  {c.name}
                </option>
              ))
            }
          </select>
        </div>

        <button
          type="submit"
          class="btn btn-primary btn-lg rounded-3xl w-full lg:w-40 shadow-lg shadow-primary/20 hover:scale-105 active:scale-95 transition-all"
        >
          Cari Sekarang
        </button>
      </form>

      {
        (query || categorySlug || tagSlug) && (
          <div class="flex justify-center mt-6">
            <a href="/blog" class="btn btn-ghost btn-sm rounded-full opacity-60 hover:opacity-100">
              ✕ Bersihkan Semua Filter
            </a>
          </div>
        )
      }
    </div>

    <!-- Results Grid -->
    <div class="relative min-h-[400px]">
      {
        articles.length === 0 ? (
          <div class="glass-depth p-20 rounded-[3rem] text-center border-dashed border-2 border-base-content/10 animate-fade-in perspective-1000">
            <div class="text-8xl mb-8 animate-float">🔍</div>
            <h3 class="text-3xl font-black mb-4 text-3d">Tidak Ditemukan</h3>
            <p class="opacity-60 max-w-md mx-auto mb-10 text-lg">
              Maaf, kami tidak dapat menemukan artikel yang cocok dengan pencarian Anda. Coba
              gunakan kata kunci lain atau pilih kategori yang tersedia.
            </p>
            <a href="/blog" class="btn btn-primary px-10 rounded-full shadow-xl">
              Kembali ke Pencarian
            </a>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            {articles.map((article, i) => (
              <div class="animate-fade-in" style={`animation-delay: ${i * 100}ms;`}>
                <ArticleCard article={article as any} />
              </div>
            ))}
          </div>
        )
      }
    </div>

    <!-- Bottom Background Decoration -->
    <div class="fixed bottom-0 left-0 w-full h-1/2 pointer-events-none z-[-1]">
      <div
        class="absolute bottom-[10%] left-[5%] w-64 h-64 bg-primary/5 rounded-full blur-[100px] animate-blob"
      >
      </div>
      <div
        class="absolute bottom-[20%] right-[5%] w-80 h-80 bg-secondary/5 rounded-full blur-[120px] animate-blob"
        style="animation-delay: 5s;"
      >
      </div>
    </div>
  </main>
</BaseLayout>
