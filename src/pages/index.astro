---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ArticleCard from "@/components/blog/ArticleCard.astro";
import { db } from "@/lib/db";

const latestArticles = await db.article.findMany({
  where: { status: "PUBLISHED" },
  include: {
    author: { select: { displayName: true, username: true, avatar: true } },
    category: { select: { name: true, slug: true, color: true } },
  },
  orderBy: { publishedAt: "desc" },
  take: 6,
});

const categories = await db.category.findMany({
  include: { _count: { select: { articles: true } } },
});
---

<BaseLayout title="BoBlog - Beranda" description="Platform blog modern dengan Astro dan Supabase">
  <main class="preserve-3d">
    <!-- ============ HERO SECTION ============ -->
    <section
      class="relative min-h-[85vh] flex items-center justify-center overflow-hidden preserve-3d"
    >
      <!-- Floating 3D decorative shapes -->
      <div class="absolute inset-0 pointer-events-none preserve-3d">
        <div
          class="absolute top-[15%] left-[10%] w-20 h-20 rounded-2xl bg-primary/20 border border-primary/30 animate-float rotate-12 backdrop-blur-sm"
          style="animation-delay: 0s; transform: translateZ(60px) rotate(12deg);"
        >
        </div>
        <div
          class="absolute top-[25%] right-[15%] w-16 h-16 rounded-full bg-secondary/25 border border-secondary/30 animate-float backdrop-blur-sm"
          style="animation-delay: 1.5s; transform: translateZ(80px);"
        >
        </div>
        <div
          class="absolute bottom-[20%] left-[20%] w-12 h-12 rounded-lg bg-accent/20 border border-accent/30 animate-float-slow -rotate-6 backdrop-blur-sm"
          style="animation-delay: 3s; transform: translateZ(40px) rotate(-6deg);"
        >
        </div>
        <div
          class="absolute bottom-[30%] right-[10%] w-24 h-24 rounded-3xl bg-primary/15 border border-primary/20 animate-float-slow backdrop-blur-sm"
          style="animation-delay: 2s; transform: translateZ(100px);"
        >
        </div>
        <div
          class="absolute top-[60%] left-[50%] w-10 h-10 rounded-full bg-info/20 border border-info/30 animate-float backdrop-blur-sm"
          style="animation-delay: 4s; transform: translateZ(50px);"
        >
        </div>
      </div>

      <!-- Hero content -->
      <div class="relative z-10 text-center max-w-4xl mx-auto px-4 perspective-1000">
        <div class="animate-fade-in" style="transform: translateZ(50px);">
          <div
            class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass-depth text-sm font-medium mb-8 animate-float-slow"
          >
            <span class="w-2 h-2 rounded-full bg-success animate-pulse"></span>
            Platform Blog Modern
          </div>

          <h1
            class="text-5xl md:text-7xl lg:text-8xl font-black mb-8 leading-none tracking-tighter"
          >
            <span
              class="bg-linear-to-r from-primary via-secondary to-accent bg-clip-text text-transparent text-3d"
            >
              BoBlog
            </span>
            <br />
            <span class="text-base-content/90 text-3xl md:text-5xl lg:text-6xl font-bold">
              Ide Tanpa Batas
            </span>
          </h1>

          <p class="text-lg md:text-xl opacity-70 max-w-2xl mx-auto mb-10 leading-relaxed">
            Temukan artikel-artikel inspiratif seputar teknologi, pemrograman, dan desain web
            kekinian. Dibuat dengan ❤️ menggunakan Astro.js.
          </p>

          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a
              href="/blog"
              class="btn btn-primary btn-lg rounded-full px-10 shadow-lg shadow-primary/30 hover:shadow-xl hover:shadow-primary/40 hover:-translate-y-1 transition-all duration-300 text-lg"
            >
              🚀 Mulai Membaca
            </a>
            <a
              href="/about"
              class="btn btn-outline btn-lg rounded-full px-10 glass-depth hover:-translate-y-1 transition-all duration-300 text-lg"
            >
              Tentang Kami
            </a>
          </div>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div
        class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-50 animate-bounce"
      >
        <span class="text-xs font-medium tracking-widest uppercase">Scroll</span>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </div>
    </section>

    <!-- ============ STATS BAR ============ -->
    <section class="max-w-5xl mx-auto px-4 -mt-8 mb-16 relative z-20">
      <div class="glass-depth rounded-2xl p-6 flex flex-wrap justify-around gap-6 perspective-1000">
        <div
          class="text-center preserve-3d hover:-translate-y-1 transition-transform duration-300"
          style="transform: translateZ(20px);"
        >
          <div
            class="text-3xl font-black bg-linear-to-r from-primary to-secondary bg-clip-text text-transparent"
          >
            {latestArticles.length}+
          </div>
          <div class="text-xs opacity-60 font-medium uppercase tracking-wider mt-1">Artikel</div>
        </div>
        <div
          class="text-center preserve-3d hover:-translate-y-1 transition-transform duration-300"
          style="transform: translateZ(20px);"
        >
          <div
            class="text-3xl font-black bg-linear-to-r from-secondary to-accent bg-clip-text text-transparent"
          >
            {categories.length}
          </div>
          <div class="text-xs opacity-60 font-medium uppercase tracking-wider mt-1">Kategori</div>
        </div>
        <div
          class="text-center preserve-3d hover:-translate-y-1 transition-transform duration-300"
          style="transform: translateZ(20px);"
        >
          <div
            class="text-3xl font-black bg-linear-to-r from-accent to-primary bg-clip-text text-transparent"
          >
            ∞
          </div>
          <div class="text-xs opacity-60 font-medium uppercase tracking-wider mt-1">Inspirasi</div>
        </div>
      </div>
    </section>

    <!-- ============ LATEST ARTICLES ============ -->
    <section class="max-w-6xl mx-auto px-4 mb-20">
      <div class="flex flex-col sm:flex-row justify-between items-center sm:items-end mb-10 gap-4">
        <div>
          <h2 class="text-3xl md:text-4xl font-black flex items-center gap-3 text-3d">
            <span class="text-4xl">✨</span> Artikel Terbaru
          </h2>
          <p class="text-sm opacity-60 mt-2 ml-14">
            Konten terhangat yang baru saja dipublikasikan
          </p>
        </div>
        <a
          href="/blog"
          class="btn btn-ghost rounded-full glass-depth hover:-translate-y-1 transition-all duration-300"
        >
          Lihat Semua →
        </a>
      </div>

      {
        latestArticles.length === 0 ? (
          <div class="glass-depth p-16 rounded-3xl text-center border-dashed border-2 border-base-content/10">
            <span class="text-6xl block mb-4">📝</span>
            <p class="opacity-60 text-lg font-medium">Belum ada artikel yang dipublikasikan.</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {latestArticles.map((article) => (
              <ArticleCard article={article as any} />
            ))}
          </div>
        )
      }
    </section>

    <!-- ============ CATEGORIES SHOWCASE ============ -->
    {
      categories.length > 0 && (
        <section class="max-w-6xl mx-auto px-4 mb-20">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-black text-3d mb-3">
              <span class="text-4xl">📂</span> Jelajahi Kategori
            </h2>
            <p class="text-sm opacity-60">Temukan topik yang paling menarik minat Anda</p>
          </div>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 perspective-1000">
            {categories.map((cat, i) => (
              <a
                href={`/blog?category=${cat.slug}`}
                class="glass-depth rounded-2xl p-6 text-center group hover:-translate-y-2 hover:shadow-2xl transition-all duration-500 preserve-3d border border-base-content/5"
                style={`animation-delay: ${i * 100}ms; transform: translateZ(${20 + i * 10}px);`}
              >
                <div
                  class="w-12 h-12 rounded-xl mx-auto mb-3 flex items-center justify-center text-2xl bg-base-content/5 group-hover:scale-110 transition-transform duration-300"
                  style={cat.color ? `background: ${cat.color}20; color: ${cat.color}` : ""}
                >
                  {cat.name.charAt(0)}
                </div>
                <h3 class="font-bold text-sm mb-1">{cat.name}</h3>
                <p class="text-xs opacity-50">{cat._count.articles} artikel</p>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <!-- ============ CTA SECTION ============ -->
    <section class="max-w-4xl mx-auto px-4 mb-20 perspective-1000">
      <div
        class="glass-depth rounded-3xl p-12 md:p-16 text-center relative overflow-hidden preserve-3d"
      >
        <div
          class="absolute inset-0 bg-linear-to-br from-primary/10 via-transparent to-secondary/10 pointer-events-none"
        >
        </div>
        <div class="relative z-10" style="transform: translateZ(30px);">
          <h2 class="text-3xl md:text-4xl font-black mb-4 text-3d">Siap Bergabung?</h2>
          <p class="opacity-70 mb-8 max-w-lg mx-auto text-lg">
            Daftar sekarang dan mulai berbagi cerita, ide, dan inspirasi Anda dengan komunitas
            BoBlog.
          </p>
          <div class="flex flex-col sm:flex-row justify-center gap-4">
            <a
              href="/auth/register"
              class="btn btn-primary btn-lg rounded-full px-10 shadow-lg shadow-primary/30 hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
            >
              Daftar Gratis 🎉
            </a>
            <a
              href="/blog"
              class="btn btn-ghost btn-lg rounded-full px-10 glass-depth hover:-translate-y-1 transition-all duration-300"
            >
              Baca Artikel Dulu
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
