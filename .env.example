# ===========================
# BoBlog Environment Variables
# ===========================

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Auth
AUTH_SECRET="your-secret-key-min-32-characters-long"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:4321/api/auth/google/callback"

# GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="http://localhost:4321/api/auth/github/callback"

# Cloudinary (Phase 2)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email — Resend (Phase 5)
RESEND_API_KEY=""

# Redis — Upstash (Phase 8)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Site
PUBLIC_SITE_URL="http://localhost:4321"
PUBLIC_SITE_NAME="BoBlog"
