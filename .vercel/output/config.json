{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/articles/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/articles/([^/]+?)/edit/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/articles/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/categories/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/tags/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/articles/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/articles/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/categories/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/comments/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/interactions/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/tags/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/auth/register/?$",
			"dest": "_render"
		},
		{
			"src": "^/author/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/blog/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/dashboard/?$",
			"dest": "_render"
		},
		{
			"src": "^/rss\\.xml/?$",
			"dest": "_render"
		}
	]
}