---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { db } from "@/lib/db";

export const prerender = false;

// Get query params
const url = new URL(Astro.request.url);
const page = parseInt(url.searchParams.get("page") || "1");
const status = url.searchParams.get("status") || "";
const search = url.searchParams.get("search") || "";
const perPage = 10;

// Build where clause
const where: any = {};
if (status) where.status = status;
if (search) {
  where.OR = [
    { title: { contains: search, mode: "insensitive" } },
    { slug: { contains: search, mode: "insensitive" } },
  ];
}

const [articles, total] = await Promise.all([
  db.article.findMany({
    where,
    include: {
      author: { select: { displayName: true, avatar: true } },
      category: { select: { name: true, color: true } },
      _count: { select: { comments: true, likes: true } },
    },
    orderBy: { createdAt: "desc" },
    skip: (page - 1) * perPage,
    take: perPage,
  }),
  db.article.count({ where }),
]);

const totalPages = Math.ceil(total / perPage);

const statusColors: Record<string, string> = {
  DRAFT: "badge-ghost",
  PUBLISHED: "badge-success",
  SCHEDULED: "badge-warning",
  ARCHIVED: "badge-error",
};
---

<AdminLayout title="Artikel">
  <!-- Action bar -->
  <div class="flex flex-col sm:flex-row gap-4 justify-between mb-6">
    <div class="flex gap-2 flex-wrap">
      <a href="/admin/articles" class:list={["btn btn-sm", !status ? "btn-primary" : "btn-ghost"]}>
        Semua ({total})
      </a>
      {
        ["DRAFT", "PUBLISHED", "SCHEDULED", "ARCHIVED"].map((s) => (
          <a
            href={`/admin/articles?status=${s}`}
            class:list={["btn btn-sm", status === s ? "btn-primary" : "btn-ghost"]}
          >
            {s}
          </a>
        ))
      }
    </div>
    <a href="/admin/articles/new" class="btn btn-primary btn-sm gap-2">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-4 w-4"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"
        ></path>
      </svg>
      Tulis Artikel Baru
    </a>
  </div>

  <!-- Search -->
  <form class="form-control mb-6">
    <div class="flex gap-2">
      <input
        type="text"
        name="search"
        value={search}
        placeholder="Cari artikel..."
        class="input input-bordered input-sm flex-1"
      />
      <button type="submit" class="btn btn-sm btn-primary">Cari</button>
    </div>
  </form>

  <!-- Table -->
  <div class="overflow-x-auto">
    <table class="table table-sm">
      <thead>
        <tr>
          <th>Judul</th>
          <th>Author</th>
          <th>Kategori</th>
          <th>Status</th>
          <th>Views</th>
          <th>Tanggal</th>
          <th>Aksi</th>
        </tr>
      </thead>
      <tbody>
        {
          articles.length === 0 ? (
            <tr>
              <td colspan="7" class="text-center py-8 opacity-50">
                {search ? `Tidak ada artikel dengan kata kunci "${search}"` : "Belum ada artikel."}
                <br />
                <a href="/admin/articles/new" class="btn btn-primary btn-sm mt-2">
                  Buat Artikel Pertama
                </a>
              </td>
            </tr>
          ) : (
            articles.map((article) => (
              <tr class="hover">
                <td>
                  <div class="max-w-xs">
                    <p class="font-medium truncate">{article.title}</p>
                    <p class="text-xs opacity-50 font-mono truncate">/{article.slug}</p>
                  </div>
                </td>
                <td>
                  <div class="flex items-center gap-2">
                    <div class="avatar">
                      <div class="w-6 rounded-full">
                        <img
                          src={
                            article.author.avatar ||
                            `https://ui-avatars.com/api/?name=${encodeURIComponent(article.author.displayName)}&size=24`
                          }
                          alt={article.author.displayName}
                        />
                      </div>
                    </div>
                    <span class="text-sm">{article.author.displayName}</span>
                  </div>
                </td>
                <td>
                  {article.category ? (
                    <span
                      class="badge badge-sm"
                      style={
                        article.category.color
                          ? `background-color: ${article.category.color}20; color: ${article.category.color}; border-color: ${article.category.color}40`
                          : ""
                      }
                    >
                      {article.category.name}
                    </span>
                  ) : (
                    <span class="text-xs opacity-40">—</span>
                  )}
                </td>
                <td>
                  <span class={`badge badge-sm ${statusColors[article.status] || ""}`}>
                    {article.status}
                  </span>
                </td>
                <td class="text-sm">{article.viewCount}</td>
                <td class="text-xs opacity-60">
                  {new Date(article.createdAt).toLocaleDateString("id-ID")}
                </td>
                <td>
                  <div class="flex gap-1">
                    <a href={`/admin/articles/${article.slug}/edit`} class="btn btn-ghost btn-xs">
                      ✏️
                    </a>
                    {article.status === "PUBLISHED" && (
                      <a
                        href={`/blog/${article.slug}`}
                        target="_blank"
                        class="btn btn-ghost btn-xs"
                      >
                        👁️
                      </a>
                    )}
                    <button
                      class="btn btn-ghost btn-xs text-error delete-btn"
                      data-id={article.id}
                      data-title={article.title}
                    >
                      🗑️
                    </button>
                  </div>
                </td>
              </tr>
            ))
          )
        }
      </tbody>
    </table>
  </div>

  <!-- Pagination -->
  {
    totalPages > 1 && (
      <div class="flex justify-center mt-6">
        <div class="join">
          {page > 1 && (
            <a
              href={`/admin/articles?page=${page - 1}${status ? `&status=${status}` : ""}${search ? `&search=${search}` : ""}`}
              class="join-item btn btn-sm"
            >
              «
            </a>
          )}
          {Array.from({ length: totalPages }, (_, i) => i + 1).map((p) => (
            <a
              href={`/admin/articles?page=${p}${status ? `&status=${status}` : ""}${search ? `&search=${search}` : ""}`}
              class:list={["join-item btn btn-sm", p === page && "btn-active"]}
            >
              {p}
            </a>
          ))}
          {page < totalPages && (
            <a
              href={`/admin/articles?page=${page + 1}${status ? `&status=${status}` : ""}${search ? `&search=${search}` : ""}`}
              class="join-item btn btn-sm"
            >
              »
            </a>
          )}
        </div>
      </div>
    )
  }

  <!-- Delete Modal -->
  <dialog id="delete-modal" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">🗑️ Arsipkan Artikel</h3>
      <p class="py-4">
        Yakin ingin mengarsipkan artikel <strong id="delete-title"></strong>? Artikel masih bisa
        dipulihkan nanti.
      </p>
      <div class="modal-action">
        <form method="dialog">
          <button class="btn btn-ghost">Batal</button>
        </form>
        <button id="confirm-delete" class="btn btn-error">Arsipkan</button>
      </div>
    </div>
  </dialog>

  <script>
    let deleteId = "";
    document.querySelectorAll(".delete-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        deleteId = (btn as HTMLElement).dataset.id || "";
        const title = (btn as HTMLElement).dataset.title || "";
        const titleEl = document.getElementById("delete-title");
        if (titleEl) titleEl.textContent = `"${title}"`;
        (document.getElementById("delete-modal") as HTMLDialogElement)?.showModal();
      });
    });

    document.getElementById("confirm-delete")?.addEventListener("click", async () => {
      if (!deleteId) return;
      try {
        const res = await fetch(`/api/articles/${deleteId}`, { method: "DELETE" });
        if (res.ok) {
          window.location.reload();
        }
      } catch (err) {
        console.error(err);
      }
    });
  </script>
</AdminLayout>
